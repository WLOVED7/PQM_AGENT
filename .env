# 应用配置
APP_NAME=质量检验知识库
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=pqm_db
DB_CHARSET=utf8mb4

# 异步引擎配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
